# ────────────────────────────────────────────────────────────────────────────
# DATABASE
# ────────────────────────────────────────────────────────────────────────────
# Локально: SQLite (создаётся автоматически).
DATABASE_URL=sqlite+aiosqlite:///./database/app.db
# Production (Railway): сюда подставится postgresql:// от Railway Postgres plugin.
# DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname

# ────────────────────────────────────────────────────────────────────────────
# TELEGRAM (опционально, для бота)
# ────────────────────────────────────────────────────────────────────────────
BOT_TOKEN=
WEBAPP_URL=https://your-app-url.com

# ────────────────────────────────────────────────────────────────────────────
# STEAM
# ────────────────────────────────────────────────────────────────────────────
# Опциональный API key — без него работает, но vanity URL разрешает медленнее
# (через парсинг XML вместо ResolveVanityURL). Получить: steamcommunity.com/dev/apikey
STEAM_API_KEY=

# Steam OpenID return URL. На проде оставь пустым — сервер сам определит из Host header.
# Задавай только если работаешь через ngrok/tunnel и Host неверный.
# STEAM_OPENID_RETURN=

# ────────────────────────────────────────────────────────────────────────────
# MARKETPLACES (опционально)
# ────────────────────────────────────────────────────────────────────────────
CSGOMARKET_API_KEY=

# ────────────────────────────────────────────────────────────────────────────
# ADMIN (production)
# ────────────────────────────────────────────────────────────────────────────
# Если не задано — admin endpoints (/api/admin/*) отключены (503).
# В Railway сгенерируй: openssl rand -hex 32
ADMIN_TOKEN=
